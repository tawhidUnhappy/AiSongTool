# Runtime
jobs/
output/
desktop-settings.json

# Python environments
.venv/
venv/
demucs-uv/.venv/
whisperx-uv/.venv/
zimage-uv/.venv/
gemma-uv/.venv/
syrex-uv/.venv/

# Portable dev-only tool runtimes (e.g. Node.js, downloaded as a zip — not a
# system install, not authored here)
.tools/

# Electron app (desktop/) — node_modules + build output, not the app's source
desktop/node_modules/
desktop/out/
desktop/dist/
desktop/*.tsbuildinfo

# Bundled static ffmpeg/ffprobe — fetched per-OS at build time by
# desktop/scripts/fetch-ffmpeg.mjs, not committed (binary, OS-specific, ~100MB+)
desktop/resources/ffmpeg/

# ACE-Step — `git clone`+`uv sync`'d into the data root at runtime, not
# authored here (acestep-cpp/ is the old, now-unused GGUF/C++ backend's
# download dir, kept ignored in case it's still lying around locally)
ace-step/
acestep-cpp/

# Python cache
__pycache__/
*.pyc
*.pyo

# Build artifacts — anchored to the repo root (setuptools' own build/ dir),
# NOT desktop/build/, which is hand-authored electron-builder config
# (icons, entitlements, uninstall helper scripts) that must be committed.
/*.egg-info/
/dist/
/build/

# Per-user data dir created by frozen installs (see aisongtool/paths.py)
.aisongtool/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
.claude/
